NODE_ENV=production
PORT=3000
APP_NAME=Revive Roots Essentials
SUPPORT_EMAIL=support@reviverootsessentials.com

# MySQL
DB_HOST=your_namecheap_db_host
DB_PORT=3306
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=revive_roots

# JWT
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d
COOKIE_SECRET=your_cookie_secret
ALLOW_REFRESH_TOKEN_IN_BODY=false

# CORS / Frontend
CORS_ORIGIN=https://revive-root-essentials.telente.site
FRONTEND_URL=https://revive-root-essentials.telente.site

# Flutterwave
FLW_PUBLIC_KEY=your_flw_public_key
FLW_SECRET_KEY=your_flw_secret_key
FLW_BASE_URL=https://api.flutterwave.com/v3
FLW_WEBHOOK_SECRET_HASH=your_flw_webhook_secret_hash

# Redis (optional but recommended for distributed rate limiting and caching)
REDIS_URL=redis://your_redis_host:6379
# REDIS_HOST=your_redis_host
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890
