NODE_ENV=development
PORT=3000
APP_NAME=Revive Roots Essentials
SUPPORT_EMAIL=support@reviverootsessentials.com

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=revive_roots

# JWT
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_me_to_a_long_random_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CORS_ORIGIN=http://localhost:5173

# Frontend callback URL
FRONTEND_URL=http://localhost:5173
ENABLE_NEWSLETTER_SCHEDULER=true
NEWSLETTER_WEEKLY_DAY_UTC=1
NEWSLETTER_WEEKLY_HOUR_UTC=9

# Squad Payment
SQUAD_PUBLIC_KEY=your_public_key
SQUAD_SECRET_KEY=your_secret_key
SQUAD_MERCHANT_ID=your_merchant_id

# Email SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_app_password

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567
