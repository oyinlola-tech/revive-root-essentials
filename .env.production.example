# ============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION - EXAMPLE
# ============================================================================
# Copy this file to .env and fill in with actual production values
# DO NOT COMMIT THIS FILE TO VERSION CONTROL
# ============================================================================

# Node Environment
NODE_ENV=production

# Server Configuration
SERVER_PORT=3000
FRONTEND_PORT=5173
HOST=0.0.0.0

# Database Configuration (CHANGE THESE VALUES)
DB_HOST=your-database-host.com
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_strong_database_password
DB_DATABASE=revive_root_essentials_prod
DB_DIALECT=mysql
DB_LOGGING=false

# Redis Configuration (Optional)
REDIS_ENABLED=true
REDIS_HOST=your-redis-host.com
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# JWT Configuration (Generate new strong secrets for production)
JWT_SECRET=generate-a-new-strong-secret-at-least-64-characters-long
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=generate-a-new-strong-refresh-secret-at-least-64-characters-long
JWT_REFRESH_EXPIRE=7d

# Payment Gateway - Flutterwave (Use LIVE keys, not test keys)
FLUTTERWAVE_PUBLIC_KEY=your-live-flutterwave-public-key
FLUTTERWAVE_SECRET_KEY=your-live-flutterwave-secret-key
FLUTTERWAVE_ENCRYPTION_KEY=your-flutterwave-encryption-key
PAYMENT_WEBHOOK_SECRET=your-flutterwave-webhook-secret

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=your-email@domain.com
SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@reviveroot.com
EMAIL_FROM_NAME=Revive Root Essentials
ADMIN_EMAIL=admin@reviveroot.com
CONTACT_RECIPIENT=support@reviveroot.com

# SMS Configuration (Twilio or other provider)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Security Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
BRUTE_FORCE_MAX_ATTEMPTS=5
BRUTE_FORCE_WINDOW_MS=900000
SESSION_SECRET=your-session-secret-min-32-chars
SESSION_TIMEOUT=3600000
CORS_ORIGINS=https://reviveroot.com,https://www.reviveroot.com
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=info
LOG_DIR=/var/log/revive-root-essentials

# Monitoring
SENTRY_DSN=your-sentry-dsn-url

# Frontend Configuration
VITE_API_BASE_URL=https://api.reviveroot.com/api
VITE_APP_NAME=Revive Root Essentials
VITE_FLUTTERWAVE_PUBLIC_KEY=your-live-flutterwave-public-key

# Feature Flags
FEATURE_PAYMENT_ENABLED=true
FEATURE_NEWSLETTER_ENABLED=true
FEATURE_REFUNDS_ENABLED=true
FEATURE_INVENTORY_TRACKING=true

# Deployment Information
DEPLOYMENT_ENVIRONMENT=production
DEPLOYMENT_REGION=your-region
