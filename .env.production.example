# Node Environment
NODE_ENV=production

# Server Configuration
PORT=3000
TRUST_PROXY=true

# Database Configuration (CHANGE THESE VALUES)
DB_HOST=your-database-host.com
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_strong_database_password
DB_NAME=revive_root_essentials_prod

# Redis Configuration (Optional)
REDIS_ENABLED=true
REDIS_HOST=your-redis-host.com
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# JWT Configuration (Generate new strong secrets for production)
JWT_SECRET=generate-a-new-strong-secret-at-least-64-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=generate-a-new-strong-refresh-secret-at-least-64-characters-long
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=generate-a-cookie-secret-at-least-32-characters-long
ALLOW_REFRESH_TOKEN_IN_BODY=false

# Payment Gateway - Flutterwave (Use LIVE keys, not test keys)
FLW_PUBLIC_KEY=your-live-flutterwave-public-key
FLW_SECRET_KEY=your-live-flutterwave-secret-key
FLW_WEBHOOK_SECRET_HASH=your-flutterwave-webhook-secret-hash

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@domain.com
EMAIL_PASS=your-app-specific-password
EMAIL_FROM=noreply@reviveroot.com
EMAIL_FROM_NAME=Revive Root Essentials
ADMIN_EMAIL=admin@reviveroot.com
CONTACT_RECIPIENT=support@reviveroot.com

# SMS Configuration (Twilio or other provider)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Security Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
BRUTE_FORCE_MAX_ATTEMPTS=5
BRUTE_FORCE_WINDOW_MS=900000
CORS_ORIGIN=https://revive-root-essentials.telente.site
TRUST_PROXY=true

# Logging
LOG_LEVEL=info
LOG_DIR=/var/log/revive-root-essentials

# Monitoring
SENTRY_DSN=your-sentry-dsn-url

# Frontend Configuration
FRONTEND_URL=https://revive-root-essentials.telente.site
APP_NAME=Revive Root Essentials
SUPPORT_EMAIL=support@reviveroot.com
SERVE_FRONTEND_FROM_BACKEND=false
VITE_API_URL=https://api.revive-root-essentials.telente.site/api
VITE_BACKEND_ORIGIN=https://api.revive-root-essentials.telente.site
VITE_SITE_URL=https://revive-root-essentials.telente.site
VITE_APP_NAME=Revive Root Essentials
VITE_FLW_PUBLIC_KEY=your-live-flutterwave-public-key

# Feature Flags
FEATURE_PAYMENT_ENABLED=true
FEATURE_NEWSLETTER_ENABLED=true
FEATURE_REFUNDS_ENABLED=true
FEATURE_INVENTORY_TRACKING=true
ENABLE_NEWSLETTER_SCHEDULER=true

# Deployment Information
DEPLOYMENT_ENVIRONMENT=production
DEPLOYMENT_REGION=your-region
