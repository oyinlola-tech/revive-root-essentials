# App
NODE_ENV=development
PORT=3000
APP_NAME=Revive Roots Essentials
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
TRUST_PROXY=false
SUPPORT_EMAIL=support@reviverootsessentials.com
ENABLE_NEWSLETTER_SCHEDULER=true

# Database (MySQL / Sequelize)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=revive_db
DB_USER=dev
DB_PASSWORD=devpass

# Superadmin initial account — set these to create the initial superadmin on startup
# The seed will only run when there is NO existing superadmin account in the database.
# Edit these before starting the app (remove the example values or change them as needed).
SUPERADMIN_NAME=Oluwayemi Oyinlola
SUPERADMIN_EMAIL=oyinlola.tech@icloud.com
SUPERADMIN_PASSWORD=Oyinlola123!

# JWT / Auth
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_a_strong_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# Redis (either REDIS_URL or host/port)
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Email (SMTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=you@example.com
EMAIL_PASS=your_email_password

# Payment (Flutterwave)
FLW_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxx
FLW_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxx
FLW_BASE_URL=https://api.flutterwave.com/v3
FLW_WEBHOOK_SECRET_HASH=your_expected_webhook_hash

# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890