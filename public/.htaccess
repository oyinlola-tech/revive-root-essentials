<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Let real files and directories resolve normally.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Send all other requests to the SPA entrypoint so React Router can handle them.
  RewriteRule ^ index.html [L]
</IfModule>
